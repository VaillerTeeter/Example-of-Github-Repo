{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json",
  "version": "0.2",
  "language": "en",

  "words": [
    "biome",
    "checkov",
    "commitlint",
    "cspell",
    "detekt",
    "eslint",
    "kubeconform",
    "lintrc",
    "phpmd",
    "phpstan",
    "rubocop",
    "ruff",
    "semgrep",
    "stylelint",
    "vale",
    "yamllint",
    "codebase",
    "configs",
    "datetime",
    "gitignore",
    "healthcheck",
    "jsonc",
    "kubectl",
    "monorepo",
    "namespace",
    "neon",
    "pnpm",
    "precommit",
    "toolchain",
    "toml",
    "workdir",
    "yaml",
    "statix",
    "ocamlformat",
    "perlcriticrc",
    "pylintrc",
    "lintr",
    "scalafmt",
    "solhint",
    "swiftlint",
    "graphqlrc",
    "taplo",
    "chktexrc",
    "chktex",
    "commitlintrc",
    "buildifier",
    "bazel",
    "cfnlintrc",
    "robocop",
    "bugprone",
    "flawfinder",
    "cppcoreguidelines",
    "bjarne",
    "hicpp"
  ],

  "flagWords": [
    "hte",
    "teh",
    "recieve",
    "occured",
    "doesnt",
    "cant",
    "dont",
    "couldnt",
    "shouldnt",
    "wont",
    "wouldnt",
    "isnt",
    "wasnt",
    "werent",
    "arent",
    "havent",
    "hasnt",
    "hadnt",
    "neednt"
  ],

  "dictionaries": [
    "en_US",
    "companies",
    "softwareTerms",
    "misc",
    "filetypes",
    "fonts",
    "html",
    "css",
    "typescript",
    "node",
    "npm",
    "aws",
    "bash",
    "docker",
    "k8s",
    "java",
    "python",
    "go",
    "php",
    "ruby",
    "rust",
    "cpp",
    "csharp",
    "sql",
    "terraform",
    "git",
    "markdown"
  ],

  "ignorePaths": [
    "node_modules",
    ".git",
    "dist",
    "build",
    "coverage",
    ".next",
    ".nuxt",
    "*.min.js",
    "*.min.css",
    "yarn.lock",
    "package-lock.json",
    "pnpm-lock.yaml",
    "*.lock",
    "CHANGELOG.md",
    "LICENSE"
  ],

  "overrides": [
    {
      "filename": "**/*.ts",
      "words": [],
      "dictionaries": ["typescript", "node", "npm"]
    },
    {
      "filename": "**/*.{js,jsx,tsx}",
      "dictionaries": ["typescript", "node", "npm"]
    },
    {
      "filename": "**/*.py",
      "dictionaries": ["python"]
    },
    {
      "filename": "**/*.go",
      "dictionaries": ["go"]
    },
    {
      "filename": "**/*.rb",
      "dictionaries": ["ruby"]
    },
    {
      "filename": "**/*.java",
      "dictionaries": ["java"]
    },
    {
      "filename": "**/*.php",
      "dictionaries": ["php"]
    },
    {
      "filename": "**/*.{yaml,yml}",
      "words": [
        "kubernetes",
        "kubectl",
        "configmap",
        "kubeconfig",
        "ingress",
        "daemonset",
        "statefulset",
        "namespace",
        "pvc",
        "svc"
      ]
    },
    {
      "filename": "**/*.{tf,tfvars}",
      "dictionaries": ["terraform", "aws"]
    },
    {
      "filename": "**/*.{md,mdx}",
      "words": []
    },
    {
      "filename": "**/*.sql",
      "dictionaries": ["sql"]
    },
    {
      "filename": "Dockerfile*",
      "dictionaries": ["docker", "bash"]
    }
  ],

  "enableGlobDot": true,
  "useGitignore": true,
  "reportUnknownWords": true,
  "maxNumberOfProblems": 50,
  "minWordLength": 4
}
